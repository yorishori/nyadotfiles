@import "theme.rasi"

configuration {
    modi:               "drun,calc";
    show-icons:         true;
    icon-theme:         "Papirus-Dark";
    drun-display-format: "{name}";
    disable-history:    false;
    scroll-method:      1;
    kb-element-next:    "Shift+Right,Control+Tab";
    kb-element-prev:    "Shift+Left,Control+ISO_Left_Tab";
    kb-mode-next:       "Tab";
    kb-mode-previous:   "ISO_Left_Tab";
}
